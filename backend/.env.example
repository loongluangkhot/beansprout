# Backend Environment Variables
# Copy this file to .env and update values for your local setup

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost/beansprout

# JWT Settings
SECRET_KEY=your-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7 days

# App Settings
APP_NAME=Beansprout
APP_VERSION=0.1.0
DEBUG=true

# CORS
CORS_ORIGINS=http://localhost:3000
